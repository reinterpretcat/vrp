# Generated by Cargo
# will have compiled files and executables
target

# Cargo.lock is tracked: this workspace ships vrp-cli as an executable, so we
# want reproducible builds (and CI runs `cargo build --locked`). The original
# upstream ignored it as a library convention; we override here.

# These are backup files generated by rustfmt
**/*.rs.bk

# IDE
.idea
*.iml
.vscode

# python experiments
*.pyc
__pycache__
.venv

# ignore files from heuristic playground
*.png
heuristic_state.json

# profiler
callgrind*

.claude